##########################
# KEDRO PROJECT

# ignore all local configuration
conf/local/**
!conf/local/.gitkeep

# ignore potentially sensitive credentials files
conf/**/*credentials*

# Ignore raw dataset only
data/raw/

# Keep processed datasets
!data/primary/
!data/intermediate/

# Keep csv files
!data/primary/*.csv
!data/intermediate/*.csv

# also keep the example dataset
!data/01_raw/companies.csv
!data/01_raw/reviews.csv
!data/01_raw/shuttles.xlsx

# ignore kedro-viz metadata
.viz

# ignore file based logs
*.log

##########################
